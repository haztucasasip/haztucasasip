---
const formFields = {
  nombre: {
    label: "Nombre completo",
    type: "text",
    placeholder: "Ej: Juan Pérez",
    required: true,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`
  },
  email: {
    label: "Correo electrónico",
    type: "email",
    placeholder: "juan@email.com",
    required: true,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`
  },
  telefono: {
    label: "Teléfono",
    type: "tel",
    placeholder: "+56 9 1234 5678",
    required: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
  }
};

const consultas = [
  { value: "", label: "Selecciona el tipo de consulta", disabled: true },
  { value: "cotizacion", label: "Cotización de modelo" },
  { value: "visita", label: "Agendar visita a terreno" },
  { value: "asesoria", label: "Asesoría técnica SIP" },
  { value: "kit", label: "Consulta por Kit de construcción" },
  { value: "otros", label: "Otras consultas" }
];

const beneficios = [
  { icon: "⚡", text: "Respuesta en 24 hrs" },
  { icon: "✓", text: "Cotización sin compromiso" },
  { icon: "🛡️", text: "Asesoría especializada" }
];
---

<section id="contacto" class="relative bg-stone-100 py-24 lg:py-32 overflow-hidden">
  <!-- Decoración de fondo -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-white to-transparent"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-amber-200/30 rounded-full blur-3xl"></div>
    <div class="absolute top-1/4 left-0 w-72 h-72 bg-stone-300/20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header mejorado -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="inline-block px-4 py-1.5 mb-4 text-xs font-semibold tracking-wider text-amber-700 uppercase bg-amber-100 rounded-full border border-amber-200">
        Estamos aquí para ayudarte
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 mb-4 tracking-tight">
        Solicita tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-600 to-amber-800">cotización</span>
      </h2>
      <p class="text-lg text-stone-600 leading-relaxed">
        Cuéntanos sobre tu proyecto y te enviaremos una propuesta personalizada en menos de 24 horas hábiles.
      </p>
    </div>

    <!-- Beneficios rápidos -->
    <div class="flex flex-wrap justify-center gap-4 mb-12">
      {beneficios.map(beneficio => (
        <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-full shadow-sm border border-stone-100 text-sm text-stone-700">
          <span class="text-amber-600 font-bold">{beneficio.icon}</span>
          <span>{beneficio.text}</span>
        </div>
      ))}
    </div>

    <!-- Card del formulario -->
    <div class="relative">
      <!-- Glow effect -->
      <div class="absolute -inset-1 bg-gradient-to-r from-amber-500/20 via-amber-600/20 to-amber-500/20 rounded-3xl blur opacity-50"></div>
      
      <div class="relative bg-white rounded-3xl shadow-xl border border-stone-100 overflow-hidden">
        <div class="grid lg:grid-cols-5">
          
          <!-- Sidebar izquierda (info) -->
          <div class="lg:col-span-2 bg-stone-900 p-8 lg:p-10 text-white relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-amber-600/20 to-transparent"></div>
            <div class="absolute top-0 right-0 w-32 h-32 bg-amber-500/10 rounded-full blur-2xl"></div>
            
            <div class="relative">
              <h3 class="text-2xl font-bold mb-6">¿Prefieres hablar directo?</h3>
              
              <div class="space-y-6">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </div>
                  <div>
                    <p class="text-sm text-stone-400 mb-1">Llámanos</p>
                    <p class="font-semibold text-lg">+56 9 1234 5678</p>
                    <p class="text-xs text-stone-500 mt-1">Lun-Vie 9:00-18:00</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  </div>
                  <div>
                    <p class="text-sm text-stone-400 mb-1">Escríbenos</p>
                    <p class="font-semibold">contacto@tuhaztucasa.cl</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div>
                    <p class="text-sm text-stone-400 mb-1">Visítanos</p>
                    <p class="font-semibold">Av. Eastman, Olmué</p>
                    <p class="text-xs text-stone-500 mt-1">V Región, Chile</p>
                  </div>
                </div>
              </div>

              <!-- WhatsApp CTA -->
              <div class="mt-8 pt-8 border-t border-white/10">
                <a 
                  href="https://wa.me/56912345678" 
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 w-full bg-green-600 hover:bg-green-500 text-white py-3 rounded-xl font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-green-600/25"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  Chatear por WhatsApp
                </a>
              </div>
            </div>
          </div>

          <!-- Formulario -->
          <div class="lg:col-span-3 p-8 lg:p-10">
            <form 
              name="cotizacion" 
              method="POST"
              data-netlify="true"
              class="space-y-6"
            >
              <input type="hidden" name="form-name" value="cotizacion" />

              <div class="grid md:grid-cols-2 gap-6">
                <!-- Nombre -->
                <div class="group">
                  <label class="block text-sm font-semibold text-stone-700 mb-2 flex items-center gap-2">
                    {formFields.nombre.label}
                    <span class="text-amber-600">*</span>
                  </label>
                  <div class="relative">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-stone-400 group-focus-within:text-amber-600 transition-colors">
                      <Fragment set:html={formFields.nombre.icon} />
                    </div>
                    <input 
                      type="text" 
                      name="nombre" 
                      required 
                      placeholder={formFields.nombre.placeholder}
                      class="w-full bg-stone-50 border border-stone-200 rounded-xl pl-12 pr-4 py-3.5 text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all duration-300 hover:border-stone-300"
                    />
                  </div>
                </div>

                <!-- Email -->
                <div class="group">
                  <label class="block text-sm font-semibold text-stone-700 mb-2 flex items-center gap-2">
                    {formFields.email.label}
                    <span class="text-amber-600">*</span>
                  </label>
                  <div class="relative">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-stone-400 group-focus-within:text-amber-600 transition-colors">
                      <Fragment set:html={formFields.email.icon} />
                    </div>
                    <input 
                      type="email" 
                      name="email" 
                      required 
                      placeholder={formFields.email.placeholder}
                      class="w-full bg-stone-50 border border-stone-200 rounded-xl pl-12 pr-4 py-3.5 text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all duration-300 hover:border-stone-300"
                    />
                  </div>
                </div>

                <!-- Teléfono -->
                <div class="group">
                  <label class="block text-sm font-semibold text-stone-700 mb-2 flex items-center gap-2">
                    {formFields.telefono.label}
                    <span class="text-stone-400 text-xs font-normal">(Opcional)</span>
                  </label>
                  <div class="relative">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-stone-400 group-focus-within:text-amber-600 transition-colors">
                      <Fragment set:html={formFields.telefono.icon} />
                    </div>
                    <input 
                      type="tel" 
                      name="telefono" 
                      placeholder={formFields.telefono.placeholder}
                      class="w-full bg-stone-50 border border-stone-200 rounded-xl pl-12 pr-4 py-3.5 text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all duration-300 hover:border-stone-300"
                    />
                  </div>
                </div>

                <!-- Tipo de consulta -->
                <div class="group">
                  <label class="block text-sm font-semibold text-stone-700 mb-2">
                    Tipo de consulta
                    <span class="text-amber-600">*</span>
                  </label>
                  <div class="relative">
                    <select 
                      name="tipoConsulta" 
                      required
                      class="w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-3.5 text-stone-900 focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all duration-300 hover:border-stone-300 appearance-none cursor-pointer"
                    >
                      {consultas.map(opt => (
                        <option value={opt.value} disabled={opt.disabled} selected={opt.disabled}>
                          {opt.label}
                        </option>
                      ))}
                    </select>
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 text-stone-400 pointer-events-none">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Mensaje -->
              <div class="group">
                <label class="block text-sm font-semibold text-stone-700 mb-2">
                  Cuéntanos sobre tu proyecto
                  <span class="text-amber-600">*</span>
                </label>
                <textarea 
                  name="mensaje" 
                  rows="4" 
                  required
                  placeholder="¿Qué modelo te interesa? ¿Tienes terreno? ¿Cuándo planeas construir?"
                  class="w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-3.5 text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all duration-300 hover:border-stone-300 resize-none"
                ></textarea>
              </div>

              <!-- Checkbox términos -->
              <div class="flex items-start gap-3">
                <input 
                  type="checkbox" 
                  id="terminos" 
                  name="terminos" 
                  required
                  class="w-5 h-5 rounded border-stone-300 text-amber-600 focus:ring-amber-500 mt-0.5 cursor-pointer"
                />
                <label for="terminos" class="text-sm text-stone-600 cursor-pointer select-none">
                  Acepto que me contacten vía email o teléfono para enviarme la cotización solicitada. 
                  <a href="/privacidad" class="text-amber-600 hover:text-amber-700 underline">Política de privacidad</a>.
                </label>
              </div>

              <!-- Botón submit -->
              <div class="pt-4">
                <button 
                  type="submit"
                  class="group relative w-full md:w-auto inline-flex items-center justify-center gap-2 bg-stone-900 text-white px-10 py-4 rounded-xl font-bold text-lg hover:bg-amber-600 transition-all duration-300 shadow-lg shadow-stone-900/20 hover:shadow-amber-600/30 hover:-translate-y-0.5 active:translate-y-0"
                >
                  Enviar solicitud
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </button>
                
                <p class="text-sm text-stone-500 mt-4 flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
                  Tus datos están protegidos y nunca serán compartidos.
                </p>
              </div>

            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust badges -->
    <div class="mt-12 flex flex-wrap justify-center items-center gap-8 opacity-60">
      <div class="flex items-center gap-2 text-stone-500 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>SSL Seguro</span>
      </div>
      <div class="flex items-center gap-2 text-stone-500 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        <span>+150 cotizaciones enviadas</span>
      </div>
      <div class="flex items-center gap-2 text-stone-500 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
        <span>Respuesta garantizada</span>
      </div>
    </div>

  </div>
</section>