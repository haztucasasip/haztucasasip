<section class="bg-[#F2F2EE] py-24">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Título -->
    <div class="text-center mb-14">
      <h2 class="text-4xl font-extrabold text-[#0B0B0B] mb-4">
        Solicita tu cotización
      </h2>
      <p class="text-gray-600 text-lg">
        Cuéntanos qué necesitas y te contactamos a la brevedad.
      </p>
    </div>

    <!-- Card -->
    <div class="bg-white/90 backdrop-blur rounded-3xl shadow-2xl p-10 md:p-14">

      <!-- FORM -->
      <form 
        name="cotizacion"
        method="POST"
        data-netlify="true"
        class="grid grid-cols-1 md:grid-cols-2 gap-8"
      >
        <input type="hidden" name="form-name" value="cotizacion" />

        <!-- Nombre -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Nombre
          </label>
          <input type="text" name="nombre" required 
            placeholder="Tu nombre completo"
            class="w-full bg-[#F7F7F5] border border-gray-300 rounded-xl px-5 py-4" />
        </div>

        <!-- Email -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Email
          </label>
          <input type="email" name="email" required
            placeholder="correo@email.com"
            class="w-full bg-[#F7F7F5] border border-gray-300 rounded-xl px-5 py-4" />
        </div>

        <!-- Teléfono -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Teléfono
          </label>
          <input type="tel" name="telefono"
            placeholder="+56 9 1234 5678"
            class="w-full bg-[#F7F7F5] border border-gray-300 rounded-xl px-5 py-4" />
        </div>

        <!-- Tipo de consulta -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Tipo de consulta
          </label>
          <select name="tipoConsulta" required
            class="w-full bg-[#F7F7F5] border border-gray-300 rounded-xl px-5 py-4">
            <option value="" disabled selected hidden>
              Selecciona una opción
            </option>
            <option value="Cotización">Cotización</option>
            <option value="Visita a terreno">Visita a terreno</option>
            <option value="Dudas generales">Dudas generales</option>
          </select>
        </div>

        <!-- Mensaje -->
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Mensaje
          </label>
          <textarea name="mensaje" rows="4" required
            class="w-full bg-[#F7F7F5] border border-gray-300 rounded-xl px-5 py-4 resize-none">
          </textarea>
        </div>

        <!-- Botón -->
        <div class="md:col-span-2 flex flex-col items-center mt-6">
          <button type="submit"
            class="bg-[#3E4446] text-white px-14 py-4 rounded-xl font-semibold">
            Enviar solicitud
          </button>

          <p class="text-sm text-gray-500 mt-4">
            Respondemos en menos de 24 horas hábiles.
          </p>
        </div>

      </form>
    </div>
  </div>
</section>