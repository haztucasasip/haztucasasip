---
const contactInfo = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    label: "Dirección",
    value: "Av. Eastman, Olmué, V Región",
    subtext: "Chile"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    label: "Horario de atención",
    value: "Lunes a Viernes",
    subtext: "9:00 - 18:00 hrs"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    label: "Teléfono",
    value: "+56 9 1234 5678",
    subtext: "WhatsApp disponible"
  }
];

const mapUrl = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3346.254339815131!2d-71.22469212356586!3d-32.997069374438404!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x96882b309f894a1b%3A0x15200f464887ad8f!2sAv.%20Adolfo%20Eastman%20Cox%2C%20Valpara%C3%ADso!5e0!3m2!1ses!2scl!4v1770338792117!5m2!1ses!2scl";
---

<section id="ubicacion" class="relative bg-stone-50 py-24 lg:py-32 overflow-hidden">
  <!-- Decoración de fondo -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-amber-100/50 to-transparent pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-amber-200/30 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 mb-4 text-xs font-semibold tracking-wider text-amber-700 uppercase bg-amber-100 rounded-full border border-amber-200">
        Encuéntranos
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 mb-4 tracking-tight">
        Visita nuestro <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-600 to-amber-800">Showroom</span>
      </h2>
      <p class="text-lg text-stone-600">
        Conoce nuestros modelos en persona, materiales de calidad y recibe asesoría personalizada sin compromiso.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-start">
      
      <!-- Columna izquierda: Info de contacto -->
      <div class="lg:col-span-2 space-y-8">
        
        <!-- Cards de contacto -->
        <div class="space-y-4">
          {contactInfo.map((item, index) => (
            <div class="group p-6 bg-white rounded-2xl shadow-sm border border-stone-100 hover:shadow-lg hover:border-amber-200 transition-all duration-300 hover:-translate-y-1">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center group-hover:bg-amber-500 group-hover:text-white transition-colors duration-300">
                  <Fragment set:html={item.icon} />
                </div>
                <div>
                  <p class="text-sm font-medium text-stone-500 uppercase tracking-wide mb-1">{item.label}</p>
                  <p class="text-lg font-bold text-stone-900">{item.value}</p>
                  <p class="text-sm text-stone-500 mt-1">{item.subtext}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA Principal -->
        <div class="p-6 bg-stone-900 rounded-2xl text-white relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-amber-600/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <h3 class="text-xl font-bold mb-2">¿Quieres visitarnos?</h3>
            <p class="text-stone-300 text-sm mb-4">Agenda una visita guiada por nuestro showroom y conoce los modelos disponibles.</p>
            
            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href={mapUrl.replace('embed', 'place')}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-amber-500 text-stone-950 px-6 py-3 rounded-xl font-semibold hover:bg-amber-400 transition-all duration-300 hover:shadow-lg hover:shadow-amber-500/25"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Ver en Google Maps
              </a>
              
              <a
                href="https://wa.me/56912345678"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-white/10 text-white border border-white/20 px-6 py-3 rounded-xl font-semibold hover:bg-white/20 transition-all duration-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Agendar visita
              </a>
            </div>
          </div>
        </div>

        <!-- Badge de confianza -->
        <div class="flex items-center gap-3 p-4 bg-amber-50 rounded-xl border border-amber-100">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-stone-900">Estacionamiento disponible</p>
            <p class="text-xs text-stone-600">Visítanos sin preocupaciones</p>
          </div>
        </div>

      </div>

      <!-- Columna derecha: Mapa -->
      <div class="lg:col-span-3">
        <div class="relative group">
          <!-- Glow effect -->
          <div class="absolute -inset-1 bg-gradient-to-r from-amber-500 to-amber-600 rounded-3xl blur opacity-20 group-hover:opacity-30 transition duration-500"></div>
          
          <!-- Mapa container -->
          <div class="relative bg-white p-2 rounded-3xl shadow-xl border border-stone-100">
            <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden bg-stone-100">
              <iframe 
                src={mapUrl}
                width="100%" 
                height="100%" 
                style="border:0; filter: grayscale(20%) contrast(1.1);" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade"
                title="Ubicación Showroom Olmué"
                class="absolute inset-0 w-full h-full"
              ></iframe>
              
              <!-- Overlay con pin animado -->
              <div class="absolute inset-0 pointer-events-none flex items-center justify-center">
                <div class="relative">
                  <div class="w-4 h-4 bg-amber-500 rounded-full animate-ping absolute inset-0"></div>
                  <div class="relative w-4 h-4 bg-amber-600 rounded-full border-2 border-white shadow-lg"></div>
                </div>
              </div>
            </div>
            
            <!-- Barra inferior del mapa -->
            <div class="flex items-center justify-between px-4 py-3 mt-2">
              <span class="text-sm text-stone-500">Olmué, V Región</span>
              <a 
                href={mapUrl.replace('embed', 'place')}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-semibold text-amber-600 hover:text-amber-700 flex items-center gap-1 transition-colors"
              >
                Ampliar mapa
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Indicaciones rápidas -->
        <div class="mt-6 grid sm:grid-cols-2 gap-4">
          <div class="flex items-center gap-3 text-sm text-stone-600">
            <div class="w-8 h-8 rounded-lg bg-stone-100 flex items-center justify-center text-stone-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h12a2 2 0 0 0 2-2v-2H10v2a2 2 0 1 1-4 0V5a2 2 0 0 0-2-2H3"/><path d="M16 3v2"/><path d="M12 3v2"/><path d="M8 3v2"/><path d="M4 11h16"/><path d="M4 15h16"/><path d="M4 7h16"/></svg>
            </div>
            <span>A 5 min del centro de Olmué</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-stone-600">
            <div class="w-8 h-8 rounded-lg bg-stone-100 flex items-center justify-center text-stone-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
            </div>
            <span>Acceso directo desde Ruta 60</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>