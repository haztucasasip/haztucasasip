---
// Datos configurables
const images = [
  "/hero.png",
  "/carrusel1.png",
  "/caru2.jpg"
];

const features = [
  { icon: "⚡", text: "Construcción en 30 días" },
  { icon: "🌡️", text: "Aislación térmica superior" },
  { icon: "💰", text: "Desde $10.000.000" }
];
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-stone-950">
  
  <!-- Fondo con carrusel suavizado -->
  <div class="absolute inset-0">
    {images.map((img, i) => (
      <img
        data-hero-bg
        src={img}
        alt=""
        class={`absolute inset-0 w-full h-full object-cover transition-all duration-1000 ease-in-out ${i === 0 ? 'opacity-100 scale-100' : 'opacity-0 scale-105'}`}
      />
    ))}
    <!-- Overlay gradiente premium -->
    <div class="absolute inset-0 bg-gradient-to-r from-stone-950/95 via-stone-950/70 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-stone-950/50 via-transparent to-transparent"></div>
  </div>

  <!-- Patrón de puntos decorativo -->
  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>

  <!-- Contenido -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-0">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      
      <!-- Columna de texto -->
      <div class="space-y-8 text-center lg:text-left">
        
        <!-- Badge superior -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-500/10 border border-amber-500/20 backdrop-blur-sm">
          <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
          <span class="text-amber-400 text-sm font-medium tracking-wide uppercase">Tecnología SIP 2026</span>
        </div>

        <!-- Título con animación -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-white leading-[1.1] tracking-tight">
          Casas <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-amber-600">prefabricadas</span> de alta eficiencia
        </h1>

        <!-- Subtítulo -->
        <p class="text-lg sm:text-xl text-stone-300 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Construcción moderna con paneles SIP. Aislación térmica superior, montaje en semanas y precios transparentes.
        </p>

        <!-- Features rápidas -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-4">
          {features.map(feature => (
            <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 border border-white/10 backdrop-blur-sm text-stone-300 text-sm">
              <span class="text-lg">{feature.icon}</span>
              <span>{feature.text}</span>
            </div>
          ))}
        </div>

        <!-- CTAs mejorados -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start pt-4">
          <a
            href="#modelos"
            class="group relative inline-flex items-center justify-center gap-2 bg-amber-500 text-stone-950 px-8 py-4 rounded-2xl font-bold text-lg hover:bg-amber-400 transition-all duration-300 shadow-lg shadow-amber-500/25 hover:shadow-amber-500/40 hover:-translate-y-0.5 active:translate-y-0"
          >
            Ver modelos
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>

          <a
            href="#contacto"
            class="group inline-flex items-center justify-center gap-2 bg-white/10 text-white backdrop-blur-sm border border-white/20 px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-white/20 hover:border-white/30 transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0"
          >
            Cotizar ahora
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </a>
        </div>

        <!-- Stats de confianza -->
        <div class="pt-8 border-t border-white/10 flex justify-center lg:justify-start gap-8 text-center">
          <div>
            <div class="text-2xl font-bold text-white">150+</div>
            <div class="text-sm text-stone-400">Casas entregadas</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-white">5 años</div>
            <div class="text-sm text-stone-400">Garantía estructural</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-white">30 días</div>
            <div class="text-sm text-stone-400">Tiempo promedio</div>
          </div>
        </div>
      </div>

      <!-- Columna de imagen con efecto -->
      <div class="relative hidden lg:block">
        <div class="relative aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl shadow-black/50 border border-white/10">
          {images.map((img, i) => (
            <img
              data-hero-main
              src={img}
              alt="Casa prefabricada moderna"
              class={`absolute inset-0 w-full h-full object-cover transition-all duration-1000 ease-in-out ${i === 0 ? 'opacity-100 scale-100' : 'opacity-0 scale-110'}`}
            />
          ))}
          
          <!-- Overlay sutil en la imagen -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
          
          <!-- Indicadores de carrusel -->
          <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2">
            {images.map((_, i) => (
              <button 
                data-slide-indicator
                class={`w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'w-8 bg-amber-500' : 'bg-white/50 hover:bg-white/80'}`}
                aria-label={`Ver imagen ${i + 1}`}
              />
            ))}
          </div>
        </div>

        <!-- Decoración flotante -->
        <div class="absolute -top-6 -right-6 w-24 h-24 bg-amber-500/20 rounded-full blur-2xl"></div>
        <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-amber-600/20 rounded-full blur-3xl"></div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce hidden lg:block">
    <div class="w-6 h-10 rounded-full border-2 border-white/30 flex justify-center pt-2">
      <div class="w-1 h-2 bg-white/60 rounded-full animate-pulse"></div>
    </div>
  </div>
</section>

<script>
  // Carrusel mejorado con indicadores
  const images = ["/hero.png", "/carrusel1.png", "/caru2.jpg"];
  let currentIndex = 0;
  
  const heroMains = document.querySelectorAll('[data-hero-main]');
  const heroBgs = document.querySelectorAll('[data-hero-bg]');
  const indicators = document.querySelectorAll('[data-slide-indicator]');

  function updateSlide(newIndex) {
    // Remover clases activas
    heroMains.forEach((img, i) => {
      img.classList.remove('opacity-100', 'scale-100');
      img.classList.add('opacity-0', 'scale-110');
    });
    
    heroBgs.forEach((img, i) => {
      img.classList.remove('opacity-100', 'scale-100');
      img.classList.add('opacity-0', 'scale-105');
    });

    indicators.forEach((ind, i) => {
      ind.classList.remove('w-8', 'bg-amber-500');
      ind.classList.add('w-2', 'bg-white/50');
    });

    // Añadir clases activas al nuevo índice
    setTimeout(() => {
      heroMains[newIndex].classList.remove('opacity-0', 'scale-110');
      heroMains[newIndex].classList.add('opacity-100', 'scale-100');
      
      heroBgs[newIndex].classList.remove('opacity-0', 'scale-105');
      heroBgs[newIndex].classList.add('opacity-100', 'scale-100');
      
      indicators[newIndex].classList.remove('w-2', 'bg-white/50');
      indicators[newIndex].classList.add('w-8', 'bg-amber-500');
    }, 50);

    currentIndex = newIndex;
  }

  // Auto-play
  setInterval(() => {
    const nextIndex = (currentIndex + 1) % images.length;
    updateSlide(nextIndex);
  }, 5000);

  // Click en indicadores
  indicators.forEach((ind, i) => {
    ind.addEventListener('click', () => updateSlide(i));
  });
</script>