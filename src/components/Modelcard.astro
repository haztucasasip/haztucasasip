---
const {
  image,
  name,
  meters,
  bedrooms,
  bathrooms,
  price,
} = Astro.props;
---
<div
  class="bg-white rounded-xl overflow-hidden shadow-md
         hover:shadow-2xl hover:-translate-y-1
         transition-all duration-300"
>

  <!-- Imagen -->
  <img
    src={image}
    alt={name}
    class="w-full h-56 object-cover"
  />

  <!-- Contenido -->
  <div class="p-6 text-[#0B0B0B]">
    <h3 class="text-xl font-bold mb-2">
      {name}
    </h3>

    <ul class="text-sm space-y-2 mb-4 text-gray-700">
        <li class="flex items-center gap-2">
            <img src="/icons/regla.png" class="h-5 mb-1">
            <span><strong>{meters} m²</strong></span>
        </li>
        <li class="flex items-center gap-2">
          <img src="/icons/cama.png" class="h-6 mb-1">
             <span>{bedrooms} Dormitorios</span>
        </li>
        <li class="flex items-center gap-2">
          <img src="/icons/baño.png" class="h-5 mb-1">
          <span>{bathrooms} Baños</span>
        </li>
    </ul>


    <div class="flex items-center justify-between">
      <span class="text-lg font-bold text-[#F4C430]">
        {price}
      </span>

      <a
        href="/cotizacion"
        class="text-sm uppercase tracking-wide border border-[#0B0B0B]
               px-4 py-2 hover:bg-[#0B0B0B] hover:text-white transition"
      >
        Ver modelos
      </a>
    </div>
  </div>
</div>
