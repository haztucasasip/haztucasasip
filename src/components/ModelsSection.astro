---
import ModelCard from "./ModelCard.astro";

const models = [
  {
    image: "/alpina/Alpina.png",
    name: "Vivienda Alpina",
    meters: 50,
    bedrooms: 2,
    bathrooms: 1,
    price: "$28.990.000",
  },
  {
    image: "/medi50/Medi.png",
    name: "Vivienda Mediterranea",
    meters: 50,
    bedrooms: 2,
    bathrooms: 1,
    price: "$34.990.000",
  },
  {
    image: "/medi80/vista2.png",
    name: "Mediterranea Modelo 80m²",
    meters: 80,
    bedrooms: 3,
    bathrooms: 2,
    price: "$42.990.000",
  },
];
---
<section class="bg-[#F5F5F2] py-20">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Título -->
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold text-[#0B0B0B] mb-2">
        Nuestros Modelos
      </h2>
      <p class="text-gray-600">
        Casas prefabricadas SIP diseñadas para tu comodidad
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {models.map((model) => (
        <ModelCard {...model} />
      ))}
    </div>

  </div>
</section>
