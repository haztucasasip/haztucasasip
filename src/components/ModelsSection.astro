---
import ModelCard from "./Modelcard.astro";
import { models } from "../data/models";

const hasMoreModels = models.length > 3;
---

<section id="modelos" class="relative bg-stone-50 py-24 lg:py-32 overflow-hidden">
  <!-- Fondo decorativo sutil -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-amber-200/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-stone-300/20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header mejorado con badge -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 mb-4 text-xs font-semibold tracking-wider text-amber-700 uppercase bg-amber-100 rounded-full border border-amber-200">
        Catálogo 2026
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 mb-4 tracking-tight">
        Nuestros <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-600 to-amber-800">Modelos</span>
      </h2>
      <p class="text-lg text-stone-600 leading-relaxed">
        Casas prefabricadas SIP diseñadas con tecnología de punta para tu comodidad y un futuro sostenible
      </p>
    </div>

    <!-- Grid mejorado con gap responsive -->
    <div class="grid gap-6 sm:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      
      {models.slice(0, 3).map((model) => (
        <ModelCard {...model} />
      ))}

      <!-- Modelos extra con animación de entrada -->
      <div id="extra-models" class="hidden contents">
        {models.slice(3).map((model, index) => (
          <div class="animate-fade-in-up" style={`animation-delay: ${index * 100}ms`}>
            <ModelCard {...model} />
          </div>
        ))}
      </div>

    </div>

    <!-- Botón Ver Más mejorado -->
    {hasMoreModels && (
      <div class="text-center mt-16">
        <button
          id="loadMore"
          class="group relative inline-flex items-center gap-2 bg-white text-stone-900 px-8 py-4 rounded-2xl font-semibold border-2 border-stone-200 hover:border-amber-500 hover:bg-amber-500 hover:text-white transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-amber-500/20 hover:-translate-y-0.5 active:translate-y-0"
        >
          <span>Ver más modelos</span>
          <svg 
            xmlns="http://www.w3.org/2000/svg" 
            width="20" 
            height="20" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2" 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            class="transition-transform duration-300 group-hover:translate-y-1"
          >
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>
      </div>
    )}

  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out forwards;
  }
</style>

<script>
  const button = document.getElementById("loadMore");
  const extra = document.getElementById("extra-models");

  button?.addEventListener("click", () => {
    extra?.classList.remove("hidden");
    button.style.display = "none";
    
    // Scroll suave hacia los nuevos modelos
    setTimeout(() => {
      extra?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  });
</script>