---
const currentYear = new Date().getFullYear();

const navigation = [
  { label: "Inicio", href: "/" },
  { label: "Modelos", href: "/#modelos" },
  { label: "Tecnología SIP", href: "/#panelsip" },
  { label: "Proceso", href: "/#proceso" },
  { label: "Contacto", href: "/#contacto" }
];

const contactInfo = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    text: "Av. Eastman, Olmué, V Región"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    text: "+56 9 1234 5678",
    href: "tel:+56912345678"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    text: "haztucasasip@gmail.com",
    href: "mailto:haztucasasip@gmail.com"
  }
];

const socialLinks = [
  {
    name: "Instagram",
    href: "https://instagram.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`
  },
  {
    name: "Facebook",
    href: "https://facebook.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`
  },
  {
    name: "WhatsApp",
    href: "https://wa.me/56912345678",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
  }
];

const legalLinks = [
  { label: "Política de privacidad", href: "/privacidad" },
  { label: "Términos de servicio", href: "/terminos" }
];
---

<footer class="relative bg-stone-950 text-white overflow-hidden">
  <!-- Decoración superior -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-500/50 to-transparent"></div>
  
  <!-- Fondo con patrón sutil -->
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Main footer content -->
    <div class="py-16 lg:py-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">
      
      <!-- Columna 1: Marca (más ancha) -->
      <div class="lg:col-span-5 space-y-6">
        <a href="/" class="inline-block">
          <img 
            src="/logofooter.png" 
            alt="HazTuCasa" 
            class="h-12 w-auto brightness-0 invert opacity-90 hover:opacity-100 transition-opacity"
          />
        </a>
        
        <p class="text-stone-400 text-sm leading-relaxed max-w-md">
          Construimos viviendas prefabricadas con <span class="text-amber-400 font-medium">paneles SIP</span> de alta calidad que combinan diseño moderno, eficiencia energética y rapidez de ejecución.
        </p>
        
        <p class="text-stone-500 text-sm leading-relaxed max-w-md">
          Excelente aislación térmica, mayor confort interior y ahorro energético significativo, adaptándose a los distintos climas y necesidades de cada familia.
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-3 pt-4">
          <span class="text-xs text-stone-500 uppercase tracking-wider font-medium">Síguenos:</span>
          <div class="flex gap-2">
            {socialLinks.map(social => (
              <a 
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-stone-400 hover:bg-amber-500 hover:text-stone-950 hover:border-amber-500 transition-all duration-300"
                aria-label={social.name}
              >
                <Fragment set:html={social.icon} />
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Columna 2: Navegación -->
      <div class="lg:col-span-3 lg:pl-8">
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-6 flex items-center gap-2">
          <span class="w-8 h-px bg-amber-500"></span>
          Navegación
        </h4>
        <ul class="space-y-3">
          {navigation.map(item => (
            <li>
              <a 
                href={item.href}
                class="group flex items-center text-stone-400 hover:text-white transition-colors duration-300 text-sm"
              >
                <span class="w-0 group-hover:w-2 h-px bg-amber-500 mr-0 group-hover:mr-2 transition-all duration-300"></span>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Contacto -->
      <div class="lg:col-span-4">
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-6 flex items-center gap-2">
          <span class="w-8 h-px bg-amber-500"></span>
          Contacto
        </h4>
        
        <ul class="space-y-4">
          {contactInfo.map(item => (
            <li class="flex items-start gap-3 group">
              <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-amber-500 group-hover:bg-amber-500 group-hover:text-stone-950 transition-all duration-300">
                <Fragment set:html={item.icon} />
              </div>
              <div class="pt-1">
                {item.href ? (
                  <a 
                    href={item.href}
                    class="text-stone-300 hover:text-white transition-colors text-sm"
                  >
                    {item.text}
                  </a>
                ) : (
                  <span class="text-stone-300 text-sm">{item.text}</span>
                )}
              </div>
            </li>
          ))}
        </ul>

        <!-- CTA pequeño -->
        <a 
          href="/#contacto"
          class="inline-flex items-center gap-2 mt-6 px-4 py-2.5 bg-amber-500/10 border border-amber-500/20 rounded-lg text-amber-400 text-sm font-medium hover:bg-amber-500 hover:text-stone-950 hover:border-amber-500 transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Solicitar cotización
        </a>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-stone-500 text-sm text-center md:text-left">
        © {currentYear} <span class="text-stone-300">HazTuCasa</span>. Todos los derechos reservados.
      </p>
      
      <div class="flex items-center gap-6">
        {legalLinks.map(link => (
          <a 
            href={link.href}
            class="text-stone-500 hover:text-stone-300 text-sm transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

  </div>
</footer>